# Compose-level ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432

# Postgres credentials
POSTGRES_DB=quant_trading
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant

# Frontend API base (injected at build time)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Scheduler cron (Asia/Shanghai timezone)
SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULER_DATA_CRON=30 15 * * 1-5
SCHEDULER_STRATEGY_CRON=40 15 * * 1-5
SCHEDULER_PAPER_TRADING_CRON=50 15 * * 1-5
SCHEDULER_BACKTEST_CRON=0 9 * * 6
