APP_NAME=Quant Trading Backend
APP_ENV=dev
APP_DEBUG=true
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite:///./quant_trading.db
LOG_LEVEL=INFO
LOG_PATH=logs/app.log
CORS_ORIGINS=*
DEFAULT_ACCOUNT=paper_account
DATA_PROVIDER=mock
TUSHARE_TOKEN=
STRATEGY_NAME=multi_factor_v1
STRATEGY_TOP_N=5
REBALANCE_WEEKDAY=0
BENCHMARK_SYMBOL=000300.SH
TIMING_MA_WINDOW=20
WEIGHT_MOMENTUM_20=0.35
WEIGHT_MOMENTUM_60=0.25
WEIGHT_VOLUME=0.20
WEIGHT_VOLATILITY=0.20
INITIAL_CAPITAL=1000000
TRADE_FEE_RATE=0.0003
MIN_TRADE_LOT=100
RISK_SINGLE_POSITION_LIMIT=0.35
RISK_STOP_LOSS_PCT=-0.08
RISK_MAX_POSITION_RATIO=0.95
RISK_MAX_DRAWDOWN_WARNING=0.10
RISK_MAX_DRAWDOWN_CRITICAL=0.20
SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULER_DATA_CRON=30 15 * * 1-5
SCHEDULER_STRATEGY_CRON=40 15 * * 1-5
SCHEDULER_PAPER_TRADING_CRON=50 15 * * 1-5
SCHEDULER_BACKTEST_CRON=0 9 * * 6
